PORT=5001
# Set to true only for local scheduler testing.
SCHEDULER_TEST_MODE=false
# Allowed frontend origin for browser requests.
FRONTEND_URL=https://lpg-agent.vercel.app
# Admin account email used for admin-only access checks.
ADMIN_EMAIL=admin@example.com
# Firebase Admin service account configuration used to verify Firebase ID tokens on the backend.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_admin_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# Gmail account used by Nodemailer.
EMAIL_USER=your_email_here
# Gmail App Password (not your normal Gmail password).
EMAIL_PASS=your_app_password
# Optional recipient for system-wide alert emails. Defaults to EMAIL_USER when empty.
EMAIL_TO=alerts@example.com
# Gemini API key used for natural-language query understanding.
GEMINI_API_KEY=your_gemini_api_key
